<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <!-- Period tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/tab_bg"
        android:padding="3dp"
        android:layout_marginBottom="16dp">
        <Button android:id="@+id/tab_day" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="日" style="@style/PeriodTab" />
        <Button android:id="@+id/tab_month" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="月" style="@style/PeriodTab" />
        <Button android:id="@+id/tab_year" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="年" style="@style/PeriodTab" />
    </LinearLayout>

    <!-- Total card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/primary"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">
            <TextView android:id="@+id/total_label" android:text="今日总消费"
                android:textColor="#FFFFFF" android:textSize="13sp" android:alpha="0.85" />
            <TextView android:id="@+id/total_amount" android:text="0.00"
                android:textColor="#FFFFFF" android:textSize="36sp" android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Category breakdown -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/surface"
        android:layout_marginBottom="8dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView android:text="分类统计" android:textSize="14sp"
                android:textStyle="bold" android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cat_breakdown_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Pie chart -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/surface">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView android:text="消费分布" android:textSize="14sp"
                android:textStyle="bold" android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />
            <com.taoli.xingqiu.view.PieChartView
                android:id="@+id/pie_chart"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
