<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView android:text="💸 检测到付费"
        android:textSize="20sp" android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <TextView android:text="消费金额" android:textSize="13sp"
        android:textColor="@color/text_secondary" android:layout_marginBottom="6dp" />
    <EditText android:id="@+id/pay_amount"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="@string/amount_hint" android:inputType="numberDecimal"
        android:paddingHorizontal="14dp" android:textSize="16sp"
        android:background="@drawable/input_bg" android:layout_marginBottom="16dp" />

    <TextView android:text="备注" android:textSize="13sp"
        android:textColor="@color/text_secondary" android:layout_marginBottom="6dp" />
    <EditText android:id="@+id/pay_note"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="@string/note_hint"
        android:paddingHorizontal="14dp" android:textSize="15sp"
        android:background="@drawable/input_bg" android:layout_marginBottom="16dp" />

    <TextView android:text="消费类型" android:textSize="13sp"
        android:textColor="@color/text_secondary" android:layout_marginBottom="8dp" />
    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/type_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:flexWrap="wrap"
        app:flexDirection="row" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">
        <Button android:id="@+id/btn_cancel_pay" android:text="@string/cancel"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:background="@drawable/btn_cancel_bg" android:textColor="@color/text_primary" />
        <Button android:id="@+id/btn_confirm_pay" android:text="@string/confirm_record"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@drawable/btn_primary_bg" android:textColor="@color/surface" />
    </LinearLayout>

</LinearLayout>
